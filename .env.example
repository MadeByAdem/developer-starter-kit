# ============================================================================
# .env.example — Template for environment variables
# ============================================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# NEVER commit the .env file to Git — it contains secrets!
# This .env.example is safe to commit because it only has placeholders.
# ============================================================================

# === Server ===
# The port your backend runs on (default: 3000)
PORT=3000
# Set to "production" when deploying, keep "development" while building locally
NODE_ENV=development

# === App ===
# Name shown in log output (optional, defaults to "app")
APP_NAME=my-app
# Log level: error, warn, info, debug (optional, defaults to "info" in dev)
LOG_LEVEL=info

# === Supabase ===
# Find these at: https://supabase.com/dashboard → select your project → Project Settings → Data API
# "Project URL" — the base URL for your Supabase project
SUPABASE_URL=https://your-project-id.supabase.co
# "anon public" key — safe to use in frontend code, respects Row Level Security policies
SUPABASE_ANON_KEY=your-anon-key-here
# "service_role" key — has FULL database access, ONLY use in backend code, never expose to users
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# === CORS ===
# The URL where your frontend runs (so the backend allows requests from it)
# Default Vite dev server runs on port 5173. Change this to your production URL when deploying.
CORS_ORIGIN=http://localhost:5173

# === Frontend (Vue with Vite) ===
# The URL of your backend API. Your frontend uses this to make API calls.
# Must start with VITE_ to be accessible in Vue code (Vite requirement).
VITE_API_URL=http://localhost:3000/api

# === Frontend (Nuxt) ===
# Same as above but for Nuxt projects. Must start with NUXT_PUBLIC_ to be accessible in Nuxt code.
# Uncomment the line below if using Nuxt instead of Vue.
# NUXT_PUBLIC_API_URL=http://localhost:3000/api
